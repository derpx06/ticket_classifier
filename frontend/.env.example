# Copy to .env if you need overrides (optional).

# Dev: where Vite forwards /api (must match backend PORT in ../backend/.env).
# If unset, vite.config.js reads PORT from ../backend/.env, else defaults to 5000.
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5001

# Optional: force axios base URL (skips /api proxy in dev if set — usually leave unset).
# VITE_API_BASE_URL=http://127.0.0.1:5001/api
