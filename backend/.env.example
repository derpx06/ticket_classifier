PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ticket_classifier
MONGODB_DB_NAME=ticket_classifier

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# File Uploads
BILL_UPLOAD_DIR=uploads/bills
BILL_UPLOAD_PUBLIC_PATH=/uploads/bills
BILL_UPLOAD_MAX_SIZE_MB=10

# OCR
OCR_SPACE_API_KEY=

# Hugging Face (Embeddings - Optional if using local)
HUGGINGFACE_API_KEY=

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Qdrant Vector DB
# Run locally: docker run -p 6333:6333 qdrant/qdrant
# Or use Qdrant Cloud: https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ticket_knowledge
